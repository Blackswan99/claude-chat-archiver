{
  "manifest_version": 3,
  "name": "Claude Chat Archiver",
  "version": "1.0.4",
  "description": "Archive your Claude.ai chats as Markdown to GitHub — uses the internal Claude API, no DOM scraping.",
  "permissions": [
    "storage",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://api.github.com/*"
  ],
  "background": {
    "scripts": ["background.bundle.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Chat Archiver"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-chat-archiver-addon@mozilla.local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
